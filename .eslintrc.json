{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:prettier/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "prettier/prettier": "error",
    "no-unused-vars": "warn",
    "eqeqeq": ["warn", "always"],
    "no-var": "warn",
    "no-debugger": "off", 
    "curly": ["error", "all"]
  }
  }

